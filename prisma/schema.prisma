generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model appointment_products {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id   String       @db.Uuid
  product_id       String       @db.Uuid
  product_name     String
  unit_price       Decimal      @db.Decimal(12, 2)
  discount_percent Int          @default(0)
  quantity         Int          @default(1)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  appointments     appointments @relation(fields: [appointment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products     @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([appointment_id], map: "idx_appointment_products_appt")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model appointment_services {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id   String       @db.Uuid
  service_id       String       @db.Uuid
  service_name     String
  unit_price       Decimal      @db.Decimal(12, 2)
  duration_minutes Int
  quantity         Int          @default(1)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  appointments     appointments @relation(fields: [appointment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services         services     @relation(fields: [service_id], references: [id], onUpdate: NoAction)

  @@index([appointment_id], map: "idx_appointment_services_appt")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This table contains exclusion constraints and requires additional setup for migrations. Visit https://pris.ly/d/exclusion-constraints for more info.
model appointments {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id            String?                @unique
  barber_id            String                 @db.Uuid
  client_id            String                 @db.Uuid
  start_at             DateTime               @db.Timestamptz(6)
  end_at               DateTime               @db.Timestamptz(6)
  status               appointment_status     @default(scheduled)
  notes                String?
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  barbershop_id        String                 @db.Uuid
  appointment_products appointment_products[]
  appointment_services appointment_services[]
  barbers              barbers                @relation(fields: [barber_id], references: [id], onUpdate: NoAction)
  users                users                  @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  barbershops          barbershops            @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_appointments_barbershop")
  payment_transactions payment_transactions[]
  subscription_usages  subscription_usages?

  @@index([barbershop_id], map: "idx_appointments_barbershop_id")
}

model barbers {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id          String?  @unique
  user_id            String?  @unique @db.Uuid
  display_name       String
  salary             Int?
  specialty          String?
  photo_url          String?
  commission_percent Int?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  barbershop_id      String   @db.Uuid

  appointments appointments[]
  users        users?         @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  barbershops  barbershops    @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_barbers_barbershop")

  monthly_subscriptions subscriptions[] @relation("MonthlyBarber")
  blocked_dates         blocked_dates[]
}

model gallery_images {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id     String?     @unique
  alt           String?
  url           String
  sort_order    Int         @default(0)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  barbershop_id String      @db.Uuid
  barbershops   barbershops @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_gallery_barbershop")

  @@index([barbershop_id], map: "idx_gallery_barbershop_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payment_transactions {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id       String?        @unique
  user_id         String?        @db.Uuid
  appointment_id  String?        @db.Uuid
  subscription_id String?        @db.Uuid
  amount          Decimal        @default(0) @db.Decimal(12, 2)
  method          payment_method
  status          payment_status @default(pending)
  status_raw      String?
  paid_at         DateTime?      @db.Timestamptz(6)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  barbershop_id   String         @db.Uuid

  mp_payment_id    String?
  mp_preference_id String?
  barbershops      barbershops    @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_payments_barbershop")
  appointments     appointments?  @relation(fields: [appointment_id], references: [id], onUpdate: NoAction)
  subscriptions    subscriptions? @relation(fields: [subscription_id], references: [id], onUpdate: NoAction)
  users            users?         @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([appointment_id], map: "idx_payments_appointment")
  @@index([subscription_id], map: "idx_payments_subscription")
  @@index([user_id], map: "idx_payments_user")
  @@index([barbershop_id], map: "idx_payments_barbershop_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model products {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id            String?                @unique
  name                 String
  description          String?
  category             String?
  price                Decimal                @db.Decimal(12, 2)
  subscriber_discount  Int                    @default(0)
  image_url            String?
  stock                Int                    @default(0)
  active               Boolean                @default(true)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  barbershop_id        String                 @db.Uuid
  appointment_products appointment_products[]
  barbershops          barbershops            @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_products_barbershop")

  @@index([barbershop_id], map: "idx_products_barbershop_id")
}

model services {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id        String? @unique
  name             String
  base_price       Decimal @db.Decimal(12, 2)
  duration_minutes Int
  image_url        String?
  active           Boolean @default(true)

  promotional_price Decimal? @db.Decimal(12, 2)
  covered_by_plan   Boolean  @default(false)

  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  barbershop_id String   @db.Uuid

  appointment_services appointment_services[]
  barbershops          barbershops            @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_services_barbershop")

  @@index([barbershop_id], map: "idx_services_barbershop_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subscription_cycles {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id     String                @db.Uuid
  period_start        DateTime              @db.Date
  period_end          DateTime              @db.Date
  cuts_included       Int
  cuts_used           Int                   @default(0)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  subscriptions       subscriptions         @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subscription_usages subscription_usages[]

  @@unique([subscription_id, period_start, period_end], map: "uq_subscription_cycle_period")
}

model subscription_plan_features {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plan_id            String             @db.Uuid
  feature            String
  sort_order         Int                @default(0)
  subscription_plans subscription_plans @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([plan_id], map: "idx_plan_features_plan")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subscription_plans {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id      String? @unique
  name           String
  price          Decimal @db.Decimal(12, 2)
  cuts_per_month Int     @default(0)
  active         Boolean @default(true)

  subtitle    String?
  color       String?
  recommended Boolean @default(false)

  mp_subscription_url    String?
  mp_preapproval_plan_id String? @unique

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  barbershop_id String?      @db.Uuid
  barbershops   barbershops? @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, map: "fk_plans_barbershop")

  subscription_plan_features subscription_plan_features[]
  subscriptions              subscriptions[]

  @@unique([barbershop_id, name], map: "uq_plan_name_per_barbershop")
  @@index([barbershop_id], map: "idx_plans_barbershop_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subscription_usages {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycle_id            String              @db.Uuid
  appointment_id      String              @unique(map: "uq_subscription_usage_appointment") @db.Uuid
  credits_used        Int                 @default(1)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  appointments        appointments        @relation(fields: [appointment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subscription_cycles subscription_cycles @relation(fields: [cycle_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model subscriptions {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id       String?             @unique
  user_id         String              @db.Uuid
  plan_id         String              @db.Uuid
  status          subscription_status @default(active)
  started_at      DateTime            @default(now()) @db.Timestamptz(6)
  next_billing_at DateTime?           @db.Timestamptz(6)
  ended_at        DateTime?           @db.Timestamptz(6)
  auto_renewal    Boolean             @default(true)
  payment_method  payment_method?

  amount                    Decimal?  @db.Decimal(12, 3)
  last_billing_at           DateTime? @db.Timestamptz(6)
  is_recurring              Boolean   @default(true)
  days_overdue              Int       @default(0)
  overdue_notification_sent Boolean   @default(false)

  mp_preapproval_id String?

  monthly_barber_id     String?   @db.Uuid
  monthly_barber_set_at DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  barbershop_id String @db.Uuid

  payment_transactions payment_transactions[]
  subscription_cycles  subscription_cycles[]
  barbershops          barbershops            @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_subscriptions_barbershop")
  subscription_plans   subscription_plans     @relation(fields: [plan_id], references: [id], onUpdate: NoAction)
  users                users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  monthly_barber barbers? @relation("MonthlyBarber", fields: [monthly_barber_id], references: [id], onUpdate: NoAction)

  // ✅ NOVO: 1 assinatura por usuário por barbearia
  @@unique([user_id, barbershop_id], map: "uq_subscription_user_barbershop")
  @@index([user_id], map: "idx_subscriptions_user")
  @@index([barbershop_id], map: "idx_subscriptions_barbershop_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_payment_methods {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String      @db.Uuid
  provider      String?
  type          String
  token         String
  brand         String?
  last4         String?
  exp_month     Int?
  exp_year      Int?
  holder_name   String?
  is_default    Boolean     @default(false)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  barbershop_id String      @db.Uuid
  barbershops   barbershops @relation(fields: [barbershop_id], references: [id], onUpdate: NoAction, map: "fk_user_payment_methods_barbershop")
  users         users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_user_payment_methods_user")
  @@index([barbershop_id], map: "idx_user_pm_barbershop_id")
}

model users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacy_id     String?   @unique
  name          String
  email         String?
  phone         String?
  role          user_role @default(client)
  is_admin      Boolean   @default(false)
  password_hash String

  cpf         String? @unique
  permissions Json?   @db.JsonB
  photo_url   String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  current_barbershop_id String      @db.Uuid
  current_barbershop    barbershops @relation("UserCurrentBarbershop", fields: [current_barbershop_id], references: [id])

  barbershop_links user_barbershops[]

  appointments         appointments[]
  barbers              barbers?
  payment_transactions payment_transactions[]
  subscriptions        subscriptions[]
  user_payment_methods user_payment_methods[]
  blocked_dates        blocked_dates[]
  dependents           dependents[]
  saved_cards          saved_cards[]
  employee_vales_received  employee_vales[]  @relation("ValeEmployee")
  employee_vales_created   employee_vales[]  @relation("ValeCreator")
  employee_payments_received employee_payments[] @relation("PaymentEmployee")
  employee_payments_created  employee_payments[] @relation("PaymentCreator")

  @@index([current_barbershop_id], map: "idx_users_current_barbershop_id")
}

model barbershops {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  cnpj       String?  @unique
  phone      String?
  email      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  appointments         appointments[]
  barbers              barbers[]
  gallery_images       gallery_images[]
  payment_transactions payment_transactions[]
  products             products[]
  services             services[]
  subscriptions        subscriptions[]
  user_payment_methods user_payment_methods[]

  // ✅ usuários vinculados (N:N)
  user_links user_barbershops[]

  // ✅ usuários que estão “com essa barbearia ativa”
  current_users users[] @relation("UserCurrentBarbershop")

  // ✅ planos dessa barbearia
  subscription_plans subscription_plans[]

  settings      barbershop_settings?
  home_info     barbershop_home_info?
  blocked_dates blocked_dates[]
  dependents    dependents[]
  saved_cards   saved_cards[]
  employee_vales    employee_vales[]
  employee_payments employee_payments[]
}

model barbershop_settings {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barbershop_id String  @unique @db.Uuid
  pix_key       String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_settings_barbershop")

  @@index([barbershop_id], map: "idx_settings_barbershop_id")
}

model user_barbershops {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  barbershop_id String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, barbershop_id], map: "uq_user_barbershop")
  @@index([user_id], map: "idx_user_barbershop_user")
  @@index([barbershop_id], map: "idx_user_barbershop_barbershop")
}

model barbershop_home_info {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barbershop_id String @unique @db.Uuid

  about_title      String?
  about_text1      String?
  about_text2      String?
  about_text3      String?
  schedule_title   String?
  schedule_line1   String?
  schedule_line2   String?
  schedule_line3   String?
  location_title   String?
  location_address String?
  location_city    String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_homeinfo_barbershop")

  @@index([barbershop_id], map: "idx_homeinfo_barbershop_id")
}

model blocked_dates {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barbershop_id String   @db.Uuid
  date          DateTime @db.Date
  reason        String?
  barber_id     String?  @db.Uuid
  created_by    String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_blocked_dates_barbershop")
  barbers     barbers?    @relation(fields: [barber_id], references: [id], onUpdate: NoAction, map: "fk_blocked_dates_barber")
  users       users       @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_blocked_dates_user")

  @@index([barbershop_id], map: "idx_blocked_dates_barbershop")
  @@index([barbershop_id, date], map: "idx_blocked_dates_barbershop_date")
}

model dependents {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  age           Int
  cpf           String
  parent_id     String      @db.Uuid
  barbershop_id String      @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @db.Timestamptz(6)

  users       users       @relation(fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_dependents_barbershop")

  @@unique([cpf, barbershop_id], map: "uq_dependent_cpf_barbershop")
  @@index([parent_id], map: "idx_dependents_parent")
  @@index([barbershop_id], map: "idx_dependents_barbershop")
}

model saved_cards {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String      @db.Uuid
  last_digits   String
  holder_name   String
  expiry_month  String
  expiry_year   String
  brand         String      @default("unknown")
  is_main       Boolean     @default(false)
  barbershop_id String      @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)

  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_saved_cards_barbershop")

  @@index([user_id], map: "idx_saved_cards_user")
  @@index([barbershop_id], map: "idx_saved_cards_barbershop")
}

model employee_vales {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id   String      @db.Uuid
  amount        Decimal     @db.Decimal(12, 2)
  note          String?
  date          DateTime    @db.Date
  created_by    String      @db.Uuid
  barbershop_id String      @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)

  employee    users       @relation("ValeEmployee", fields: [employee_id], references: [id], onUpdate: NoAction)
  creator     users       @relation("ValeCreator", fields: [created_by], references: [id], onUpdate: NoAction)
  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_employee_vales_barbershop")

  @@index([employee_id], map: "idx_employee_vales_employee")
  @@index([barbershop_id], map: "idx_employee_vales_barbershop")
}

model employee_payments {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id    String   @db.Uuid
  employee_name  String
  period         String
  period_start   String
  period_end     String
  base_salary    Decimal  @default(0) @db.Decimal(12, 2)
  commission     Decimal  @default(0) @db.Decimal(12, 2)
  total_vales    Decimal  @default(0) @db.Decimal(12, 2)
  net_amount     Decimal  @default(0) @db.Decimal(12, 2)
  paid_at        DateTime @default(now()) @db.Timestamptz(6)
  paid_by        String   @db.Uuid
  barbershop_id  String   @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  employee    users       @relation("PaymentEmployee", fields: [employee_id], references: [id], onUpdate: NoAction)
  creator     users       @relation("PaymentCreator", fields: [paid_by], references: [id], onUpdate: NoAction)
  barbershops barbershops @relation(fields: [barbershop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_employee_payments_barbershop")

  @@index([employee_id], map: "idx_employee_payments_employee")
  @@index([barbershop_id], map: "idx_employee_payments_barbershop")
}

enum appointment_status {
  scheduled
  confirmed // ✅ mock
  completed
  cancelled
  no_show
}

enum payment_method {
  pix
  debito
  credito
  dinheiro
  local
  subscription
}

enum payment_status {
  pending
  approved
  paid
  failed
  refunded
  covered
}

enum subscription_status {
  active
  paused
  cancelled
  expired
}

enum user_role {
  admin
  barber
  client
  receptionist // ✅ mock
}
